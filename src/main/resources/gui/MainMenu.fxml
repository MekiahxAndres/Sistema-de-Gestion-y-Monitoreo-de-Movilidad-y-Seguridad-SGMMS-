<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.input.MouseEvent?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml"
           fx:controller="controller.MainMenuController"
           prefWidth="800" prefHeight="600">

    <ImageView fx:id="backgroundImage"
               preserveRatio="false"
               StackPane.alignment="CENTER">
        <StackPane.margin>
            <Insets top="0" right="0" bottom="0" left="0"/>
        </StackPane.margin>
    </ImageView>


    <VBox spacing="20" alignment="CENTER">
        <padding><Insets top="100"/></padding>

        <Text text="SGMMS Palmira"
              style="-fx-font-size: 60px; -fx-font-weight: bold; -fx-fill: #0077cc; -fx-effect: dropshadow(gaussian, black, 2, 0.6, 1, 1);" />

        <Button fx:id="startButton" text="Iniciar" prefWidth="200" prefHeight="50" onMouseEntered="#zoomIn" onMouseExited="#zoomOut">
            <effect><DropShadow/></effect>
            <font><Font size="18"/></font>
        </Button>

        <Button fx:id="exitButton" text="Salir" prefWidth="200" prefHeight="50" onMouseEntered="#zoomIn" onMouseExited="#zoomOut">
            <effect><DropShadow/></effect>
            <font><Font size="18"/></font>
        </Button>
    </VBox>
</StackPane>

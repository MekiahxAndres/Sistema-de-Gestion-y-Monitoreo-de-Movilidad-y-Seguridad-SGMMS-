<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.IncidentPanelController"
      spacing="20"
      style="-fx-padding: 40; -fx-background-color: white;">

    <Label text="🗂 Panel de Incidentes"
           style="-fx-font-size: 24px; -fx-text-fill: #2c3e50;" />

    <ScrollPane fitToWidth="true" prefHeight="400">
        <VBox fx:id="incidentList" spacing="12"
              style="-fx-padding: 10;" />
    </ScrollPane>

    <Button text="🔙 Volver"
            onAction="#goBack"
            style="-fx-font-size: 14px; -fx-background-color: #bdc3c7; -fx-text-fill: black;" />
</VBox>

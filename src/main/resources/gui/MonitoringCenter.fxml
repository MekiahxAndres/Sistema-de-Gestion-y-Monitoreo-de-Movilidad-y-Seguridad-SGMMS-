<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.MonitoringCenterController"
            prefWidth="960" prefHeight="600"
            style="-fx-background-color: white; -fx-padding: 20;">

    <VBox spacing="20" layoutX="40" layoutY="20">
        <Label text="📍 Centro de Monitoreo"
               style="-fx-font-size: 22px; -fx-font-weight: bold;" />

        <Label fx:id="descriptionLabel"
               text="Incidente detectado:"
               wrapText="true"
               style="-fx-font-size: 16px;" />

        <HBox spacing="10">
            <Button text="🚑 Asignar Ambulancia" onAction="#assignAmbulance"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white;" />
            <Button text="🚓 Asignar Policía" onAction="#assignPolice"
                    style="-fx-background-color: #2980b9; -fx-text-fill: white;" />
            <Button text="🚒 Asignar Bomberos" onAction="#assignFiretruck"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white;" />
        </HBox>

        <Button text="🔙 Volver" onAction="#goBack"
                style="-fx-background-color: #bdc3c7; -fx-text-fill: black;" />
    </VBox>
</AnchorPane>
